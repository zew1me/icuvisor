        "value": 255
      }
    },
    {
      "sport": "Swim",
      "threshold_pace": {
        "unit": "seconds_per_100y",
        "value": 90
      }
    },
    {
      "ftp": 290,
      "recalc_hr_zones": false,
      "sport": "Ride",
      "threshold_hr": 168,
      "zones": [
        {
          "boundaries": [
            150,
            200,
            250,
            300
          ],
          "kind": "power",
          "names": [
            "Endurance",
            "Tempo",
            "Threshold",
            "VO2"
          ]
        }
      ]
    }
  ],
  "properties": {
    "athlete_id": {
      "description": "Target athlete; defaults to selected athlete in coach mode, or the only athlete otherwise. Format: i12345 or 12345.",
      "type": "string"
    },
    "ftp": {
      "description": "Functional Threshold Power in watts for the selected sport.",
      "minimum": 1,
      "type": "integer"
    },
    "recalc_hr_zones": {
      "default": true,
      "description": "Whether intervals.icu should recalculate heart-rate zones for the updated sport; defaults to true.",
      "type": "boolean"
    },
    "sport": {
      "description": "Sport setting to update, matching intervals.icu sport type (for example Ride, Run, Swim).",
      "enum": [
        "Ride",
        "Run",
        "Swim",
        "VirtualRide",
        "Walk",
        "Hike",
        "Rowing",
        "WeightTraining",
        "AlpineSki",
        "NordicSki",
        "Other"
      ],
      "type": "string"
    },
    "threshold_hr": {
      "description": "Threshold heart rate in bpm for the selected sport.",
      "minimum": 1,
      "type": "integer"
    },
    "threshold_pace": {
      "additionalProperties": false,
      "description": "Threshold pace with an explicit pace-duration unit; seconds_per_km is 4:15/km as 255, seconds_per_mile is 8:00/mi as 480, and seconds_per_100y is 1:30/100y as 90.",
      "properties": {
        "unit": {
          "description": "Pace-duration unit for threshold_pace value.",
          "enum": [
            "seconds_per_km",
            "seconds_per_mile",
            "seconds_per_100m",
            "seconds_per_100y",
            "seconds_per_500m",
            "minutes_per_km",
            "minutes_per_mile"
          ],
          "type": "string"
        },
        "value": {
          "description": "Threshold pace duration in the provided unit, not speed.",
          "exclusiveMinimum": 0,
          "type": "number"
        }
      },
      "required": [
        "value",
        "unit"
      ],
      "type": "object"
    },
    "zones": {
      "description": "Optional destructive replacement zone definitions. Supplying zones overwrites prior power/hr/pace zone definitions for this sport and is rejected unless ICUVISOR_DELETE_MODE=full.",
      "items": {
        "additionalProperties": false,
        "properties": {
          "boundaries": {
            "description": "Ordered zone boundary values: watts for power, bpm for hr, and pace durations in seconds per sport pace distance for pace (for example seconds_per_km or seconds_per_mile), not speed.",
            "items": {
              "minimum": 0,
              "type": "number"
            },
            "minItems": 1,
            "type": "array"
          },
          "kind": {
            "description": "Zone family to overwrite.",
            "enum": [
              "power",
              "hr",
              "pace"
            ],
            "type": "string"
          },
          "names": {
            "description": "Optional zone names; when supplied, length must match boundaries.",
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        },
        "required": [
          "kind",
          "boundaries"
        ],
        "type": "object"
      },
      "type": "array"
    }
  },
  "required": [
    "sport"
  ],
  "type": "object"
}
