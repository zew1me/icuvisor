{
  "additionalProperties": false,
  "properties": {
    "athlete_id": {
      "description": "Target athlete; defaults to selected athlete in coach mode, or the only athlete otherwise. Format: i12345 or 12345.",
      "type": "string"
    },
    "category": {
      "default": "WORKOUT",
      "description": "Optional upstream event category filter.",
      "type": "string"
    },
    "end_date": {
      "description": "Athlete-local inclusive end date YYYY-MM-DD.",
      "type": "string"
    },
    "event_type": {
      "description": "Optional exact case-insensitive event type filter.",
      "type": "string"
    },
    "include_full": {
      "default": false,
      "description": "When true, include event-level pairing audit rows.",
      "type": "boolean"
    },
    "sport": {
      "description": "Optional exact case-insensitive sport/type filter.",
      "type": "string"
    },
    "start_date": {
      "description": "Athlete-local inclusive start date YYYY-MM-DD.",
      "type": "string"
    },
    "target_metric": {
      "default": "time",
      "description": "Target/actual metric used for compliance.",
      "enum": [
        "time",
        "distance",
        "load"
      ],
      "type": "string"
    },
    "tolerance_percent": {
      "default": 20,
      "description": "Absolute percent delta allowed for compliance.",
      "maximum": 100,
      "minimum": 0,
      "type": "number"
    }
  },
  "required": [
    "start_date",
    "end_date"
  ],
  "type": "object"
}
