  "properties": {
    "athlete_id": {
      "description": "Target athlete; defaults to selected athlete in coach mode, or the only athlete otherwise. Format: i12345 or 12345.",
      "type": "string"
    },
    "ftp": {
      "description": "Optional Functional Threshold Power in watts for the new sport setting.",
      "minimum": 1,
      "type": "integer"
    },
    "indoor_ftp": {
      "description": "Optional indoor Functional Threshold Power in watts for the new sport setting.",
      "minimum": 1,
      "type": "integer"
    },
    "sport": {
      "description": "Sport setting to create, matching an intervals.icu sport type that has no existing setting (for example Ride, Run, Swim).",
      "enum": [
        "Ride",
        "Run",
        "Swim",
        "VirtualRide",
        "Walk",
        "Hike",
        "Rowing",
        "WeightTraining",
        "AlpineSki",
        "NordicSki",
        "Other"
      ],
      "type": "string"
    },
    "threshold_hr": {
      "description": "Optional threshold heart rate in bpm for the new sport setting.",
      "minimum": 1,
      "type": "integer"
    },
    "threshold_pace": {
      "additionalProperties": false,
      "description": "Optional threshold pace with an explicit pace-duration unit; seconds_per_km is 4:15/km as 255, seconds_per_mile is 8:00/mi as 480, and seconds_per_100y is 1:30/100y as 90.",
      "properties": {
        "unit": {
          "description": "Pace-duration unit for threshold_pace value.",
          "enum": [
            "seconds_per_km",
            "seconds_per_mile",
            "seconds_per_100m",
            "seconds_per_100y",
            "seconds_per_500m",
            "minutes_per_km",
            "minutes_per_mile"
          ],
          "type": "string"
        },
        "value": {
          "description": "Threshold pace duration in the provided unit, not speed.",
          "exclusiveMinimum": 0,
          "type": "number"
        }
      },
      "required": [
        "value",
        "unit"
      ],
      "type": "object"
    }
  },
  "required": [
    "sport"
  ],
  "type": "object"
}
